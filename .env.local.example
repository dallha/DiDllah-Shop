# ──────────────────────────────────────────────────────────────────────────────
# DiDallah Shop — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# .env.local est ignoré par Git (voir .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — récupérer ces valeurs dans Settings → API de ton projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin secret (fallback si Supabase est indisponible)
# Utilisé par le middleware et la page de login pour protéger /admin
ADMIN_SECRET=change_me_to_a_strong_password
